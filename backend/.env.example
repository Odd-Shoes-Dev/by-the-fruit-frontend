# Copy to .env and fill in values. Do not commit .env.

# SECURITY (required)
SECRET_KEY=your-django-secret-key-here
DEBUG=1

# HOSTS (required for runserver / CORS)
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# If using HTTPS in production:
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ADMIN (required for create_super_user command)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourSecurePassword123

# DATABASE: sqlite (default) or postgres
DB_CHOICE=sqlite
# For Postgres, configure via dj_database_url (e.g. DATABASE_URL env var in settings).

# OPTIONAL
SITE_NAME=By The Fruit
# CELERY_BROKER_URL=redis://localhost:6379/0
